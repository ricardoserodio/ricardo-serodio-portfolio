---

<BaseLayout
  lang="en"
  title="Ricardo Serôdio — Professional Portfolio"
  description="Professional portfolio of Ricardo Serôdio — banking operations, wealth management, financial data quality, banking analytics and public finance portfolio projects."
  canonical="https://www.ricardoserodio.com/"
>
  <SiteHeader
    navItems={navItems}
    homeHref="/"
    languageHref="/pt"
    languageLabel="PT"
    ariaLabel="Main navigation"
  />

  <main>
      <HeroCinematic content={hero} />

      <section id="summary" class="section">
        <div class="section-inner">
          <div class="section-header">
            <p class="eyebrow">Professional summary</p>
            <h2>Finance background with a data-driven portfolio direction.</h2>
          </div>

          <div class="summary-card card">
            <p>
              I am an EU-based banking professional with experience across retail banking operations, personal wealth management, investment advisory support and regulated financial environments. My background includes financial products, credit processes, client relationship management, documentation review and regulatory compliance, including AML/CFT, KYC/CDD and MiFID II.
            </p>
            <p>
              I am currently combining practical banking experience with financial data quality and banking analytics through public portfolio projects covering Python/Streamlit financial tools, term deposit comparison, source mapping, net yield simulation, validation workflows and human-in-the-loop review.
            </p>
          </div>
        </div>
      </section>

      <section id="experience" class="section">
        <div class="section-inner">
          <div class="section-header">
            <p class="eyebrow">Experience</p>
            <h2>Banking and regulated financial environments.</h2>
          </div>

          <div class="grid grid-2">
            {experience.map((item) => (
              <article class="card experience-card">
                <div>
                  <p class="eyebrow">{item.period}</p>
                  <h3>{item.company}</h3>
                  <p class="meta">{item.role} · {item.location}</p>
                  <p>{item.description}</p>
                  <ul class="bullet-list">
                    {item.bullets.map((bullet) => (
                      <li>{bullet}</li>
                    ))}
                  </ul>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="projects" class="section">
        <div class="section-inner">
          <div class="section-header">
            <p class="eyebrow">Portfolio projects</p>
            <h2>Public work connecting finance, data quality and analytics.</h2>
          </div>

          <div class="grid grid-2">
            {projects.map((project) => (
              <article class="card project-card">
                <div>
                  <p class="eyebrow">{project.status}</p>
                  <h3>{project.title}</h3>
                  <p>{project.description}</p>

                  <div class="tag-list">
                    {project.stack.map((tag) => (
                      <span>{tag}</span>
                    ))}
                  </div>

                  {project.links.length > 0 && (
                    <div class="link-row">
                      {project.links.map((link) => (
                        <a
                          href={link.href}
                          target="_blank"
                          rel="noopener noreferrer"
                        >
                          {link.label}
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="skills" class="section">
        <div class="section-inner">
          <div class="section-header">
            <p class="eyebrow">Skills</p>
            <h2>Finance, operations, data quality and analytics.</h2>
          </div>

          <div class="grid grid-3">
            {skillGroups.map((group) => (
              <article class="card skill-card">
                <h3>{group.title}</h3>
                <div class="tag-list">
                  {group.skills.map((skill) => (
                    <span>{skill}</span>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="certifications" class="section">
        <div class="section-inner">
          <div class="section-header">
            <div>
              <p class="eyebrow">Certifications & Learning</p>
              <h2>Certifications across capital markets, compliance, banking and analytics.</h2>
            </div>
          </div>

          <div class="credential-board">
            <article class="credential-panel">
              <div class="credential-panel-header">
                <h3>Completed credentials</h3>
                <span>{completedCredentials.length} credentials</span>
              </div>

              <div class="credential-grid completed-grid">
                {completedCredentials.map((credential) => (
                  <a
                    class="credential-pill credential-link"
                    href={credential.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`${credential.action}: ${credential.name}`}
                  >
                    <span>{credential.name}</span>
                    <small>{credential.action}</small>
                  </a>
                ))}
              </div>

              <p class="credential-note">
                Redacted public copies are used where appropriate. Original certificates available upon request.
              </p>
            </article>

            <article class="credential-panel">
              <div class="credential-panel-header">
                <h3>Learning roadmap</h3>
                <span>In progress</span>
              </div>

              <div class="credential-grid roadmap-grid">
                {learningRoadmap.map((item) => (
                  <span class="credential-pill roadmap-pill">{item}</span>
                ))}
              </div>
            </article>
          </div>
        </div>
      </section>

      <section id="career-focus" class="section">
        <div class="section-inner">
          <div class="section-header">
            <div>
              <p class="eyebrow">Career focus</p>
              <h2>International opportunities in finance, data and operations.</h2>
            </div>
          </div>

          <div class="career-board">
            {careerFocus.map((item) => (
              <span class="career-pill">{item}</span>
            ))}
          </div>
        </div>
      </section>

      <section id="contact" class="section contact-section">
        <div class="section-inner">
          <div class="contact-card">
            <div>
              <p class="eyebrow">Contact</p>
              <h2>Let’s connect.</h2>
              <p>
                Open to relevant opportunities across banking operations, wealth management, financial data quality, banking analytics, fintech operations and AI-assisted finance workflows.
              </p>
            </div>

            <div class="contact-actions">
              <a class="button button-primary" href="mailto:contact@ricardoserodio.com">Email</a>
              <a
                class="button button-secondary"
                href="https://www.linkedin.com/in/rsbig/"
                target="_blank"
                rel="noopener noreferrer"
              >
                LinkedIn
              </a>
              <a
                class="button button-secondary"
                href="https://github.com/ricardoserodio"
                target="_blank"
                rel="noopener noreferrer"
              >
                GitHub
              </a>
            </div>
          </div>
        </div>
      </section>
    </main>

  <SiteFooter lang="en" />
</BaseLayout>

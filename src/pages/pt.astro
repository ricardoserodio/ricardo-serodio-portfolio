const currentYear = new Date().getFullYear();
---

<html lang="pt">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Ricardo Serôdio | Operações Bancárias & Financial Data Quality</title>
    <meta
      name="description"
      content="Website profissional de Ricardo Serôdio, focado em operações bancárias, wealth management, financial data quality, banking analytics e AI finance."
    />
  </head>

  <body>
    <div class="page">
      <header class="header">
        <nav class="container nav" aria-label="Navegação principal">
          <a class="logo" href="/pt">Ricardo Serôdio</a>

          <div class="nav-links">
            <a href="#summary">Resumo</a>
            <a href="#experience">Experiência</a>
            <a href="#projects">Projectos</a>
            <a href="#skills">Skills</a>
            <a href="#certifications">Certificações</a>
            <a href="#contact">Contacto</a>
            <a class="lang-switch" href="/">PT | EN</a>
          </div>
        </nav>
      </header>

      <main>
        <section class="hero">
          <div class="container hero-grid">
            <div>
              <div class="eyebrow">
                Portefólio Profissional Público
              </div>

              <h1 class="hero-title">
                Ricardo <span>Serôdio</span>
              </h1>

              <p class="hero-subtitle">
                Operações Bancárias | Wealth Management | Financial Data Quality | Banking Analytics
              </p>

              <p class="location">
                Olhão, Portugal · Disponível para oportunidades remotas, híbridas e internacionais na Europa e para funções globais remotas seleccionadas.
              </p>

              <div class="hero-actions">
                <a
                  class="btn btn-primary"
                  href={linkedinUrl}
                  target="_blank"
                  rel="noreferrer"
                >
                  Ver LinkedIn
                </a>

                <a
                  class="btn"
                  href={githubUrl}
                  target="_blank"
                  rel="noreferrer"
                >
                  Ver GitHub
                </a>

                <a class="btn" href={cvUrl}>
                  Descarregar CV
                </a>

                <a class="btn" href="#projects">
                  Ver Portefólio
                </a>
              </div>
            </div>

            <aside class="hero-card" aria-label="Narrativa profissional">
              <div class="hero-card-title">Narrativa Central</div>

              <ul class="hero-card-list">
                <li>Experiência em banca</li>
                <li>Qualidade de dados financeiros</li>
                <li>Banking analytics</li>
                <li>Portefólio público</li>
                <li>Foco internacional de carreira</li>
              </ul>
            </aside>
          </div>
        </section>

        <section id="summary" class="section">
          <div class="container">
            <div class="section-header">
              <div>
                <div class="section-kicker">Resumo Profissional</div>
                <h2>Experiência em finanças com uma direcção orientada a dados.</h2>
              </div>
            </div>

            <div class="summary-card">
              <p>
                Profissional de operações bancárias e wealth management com experiência em serviços financeiros
                regulados, produtos financeiros, processos de crédito, AML/KYC, MiFID II, revisão documental,
                comunicação com stakeholders e validação de dados de clientes. Actualmente a construir um portefólio
                público focado em financial data quality, banking analytics, SQL, Power BI, Python for Finance e uso
                responsável de IA em workflows financeiros.
              </p>
            </div>
          </div>
        </section>

        <section id="experience" class="section">
          <div class="container">
            <div class="section-header">
              <div>
                <div class="section-kicker">Experiência</div>
                <h2>Banca e ambientes financeiros regulados.</h2>
              </div>

              <p class="section-intro">
                Experiência em operações de banca de retalho, wealth management, produtos financeiros, crédito,
                seguros, documentação de clientes, workflows regulados e comunicação com stakeholders.
              </p>
            </div>

            <div class="grid grid-2">
              {experience.map((item) => (
                <article class="card">
                  <h3>{item.company}</h3>
                  <div class="meta">{item.role} · {item.period}</div>
                  <p>{item.description}</p>

                  <ul class="bullet-list">
                    {item.highlights.map((highlight) => (
                      <li>{highlight}</li>
                    ))}
                  </ul>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section id="projects" class="section">
          <div class="container">
            <div class="section-header">
              <div>
                <div class="section-kicker">Projectos de Portefólio</div>
                <h2>Trabalho público que liga finanças, qualidade de dados e analytics.</h2>
              </div>

              <p class="section-intro">
                Projectos públicos ou preparados para portefólio, criados para demonstrar conhecimento financeiro
                prático, análise estruturada, validação de dados e uso responsável de tecnologia em workflows financeiros.
              </p>
            </div>

            <div class="grid grid-2">
              {projects.map((project) => (
                <article class="card">
                  <div class="status">{project.status}</div>
                  <h3>{project.name}</h3>
                  <p>{project.description}</p>

                  <div class="tags">
                    {project.skills.map((skill) => (
                      <span class="tag">{skill}</span>
                    ))}
                  </div>

                  <div class="card-actions">
                    {project.github && (
                      <a class="card-link" href={project.github} target="_blank" rel="noreferrer">
                        GitHub →
                      </a>
                    )}

                    {project.live && (
                      <a class="card-link" href={project.live} target="_blank" rel="noreferrer">
                        App →
                      </a>
                    )}
                  </div>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section id="skills" class="section">
          <div class="container">
            <div class="section-header">
              <div>
                <div class="section-kicker">Skills</div>
                <h2>Finanças, operações, qualidade de dados e analytics.</h2>
              </div>
            </div>

            <div class="grid grid-3">
              {skills.map((skillGroup) => (
                <article class="card skill-group">
                  <h3>{skillGroup.group}</h3>

                  <ul class="skill-list">
                    {skillGroup.items.map((skill) => (
                      <li>{skill}</li>
                    ))}
                  </ul>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section id="certifications" class="section">
          <div class="container">
            <div class="section-header">
              <div>
                <div class="section-kicker">Certificações & Aprendizagem</div>
                <h2>
                  Certificações em mercados financeiros, wealth management, compliance e banking analytics.
                </h2>
              </div>

              <p class="section-intro">
                Certificações concluídas e prioridades de aprendizagem seleccionadas para reforçar uma trajectória de
                carreira em banca, financial research, data quality, business intelligence e AI-assisted finance workflows.
              </p>
            </div>

            <div class="summary-card certifications-block">
              <h3>Certificações Concluídas</h3>

              <div class="focus-list">
                {certifications.map((item) => (
                  <a
                    class="focus-item"
                    href={item.url}
                    target="_blank"
                    rel="noreferrer"
                    title={`${item.name} – ${item.provider}`}
                  >
                    {item.name} — {item.provider}
                  </a>
                ))}
              </div>
            </div>

            <div class="summary-card certifications-block">
              <h3>Roadmap de Aprendizagem Seleccionado</h3>

              <div class="focus-list">
                {learningRoadmap.map((item) => (
                  <span class="focus-item">{item}</span>
                ))}
              </div>
            </div>
          </div>
        </section>

        <section class="section">
          <div class="container">
            <div class="section-header">
              <div>
                <div class="section-kicker">Foco de Carreira</div>
                <h2>Oportunidades internacionais em finanças, dados e operações.</h2>
              </div>

              <p class="section-intro">
                Aberto a funções onde experiência bancária, conhecimento de produtos financeiros, consciência de
                qualidade de dados e pensamento analítico possam apoiar workflows financeiros regulados, data-driven ou
                assistidos por IA.
              </p>
            </div>

            <div class="focus-list">
              {careerFocus.map((item) => (
                <span class="focus-item">{item}</span>
              ))}
            </div>
          </div>
        </section>

        <section id="contact" class="section">
          <div class="container">
            <div class="contact-box">
              <div>
                <div class="section-kicker">Contacto</div>
                <h2>Vamos falar.</h2>
                <p>
                  Baseado em Olhão, Portugal. Disponível para oportunidades remotas, híbridas e internacionais na Europa e para funções globais remotas seleccionadas.
                </p>
              </div>

              <div class="contact-actions">
                <a
                  class="btn"
                  href={linkedinUrl}
                  target="_blank"
                  rel="noreferrer"
                >
                  LinkedIn
                </a>

                <a
                  class="btn"
                  href={githubUrl}
                  target="_blank"
                  rel="noreferrer"
                >
                  GitHub
                </a>

                <a class="btn" href={emailUrl}>
                  Email
                </a>

                <a class="btn" href={cvUrl}>
                  CV
                </a>
              </div>
            </div>
          </div>
        </section>
      </main>

      <footer class="footer">
        <div class="container footer-inner">
          <span>© {currentYear} Ricardo Serôdio. Portefólio Profissional.</span>
          <span>Experiência em banca · Financial data quality · Banking analytics · Portefólio público</span>
        </div>
      </footer>
    </div>
  </body>
</html>
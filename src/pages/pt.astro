    description:
      "Ferramenta de simulação de viabilidade financeira e DSTI inspirada em processos bancários, focada em literacia financeira, validação de dados, explicabilidade e consciencialização de risco.",
    skills: [
      "Análise de Crédito",
      "DSTI",
      "Literacia Financeira",
      "Risco",
      "Validação de Dados",
      "Explicabilidade",
    ],
    github: "",
    live: "",
  },
  {

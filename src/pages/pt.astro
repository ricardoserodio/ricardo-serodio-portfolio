---
import "../styles/global.css";

const linkedinUrl = "https://www.linkedin.com/in/rsbig/";
const githubUrl = "https://github.com/ricardoserodio";
const emailUrl = "mailto:contact@ricardoserodio.com";
const cvUrl = "/cv/ricardo-serodio-cv.pdf";

const careerFocus = [
  "Wealth Management",
  "Financial Research",
  "Banking Analytics",
  "Financial Data Quality",
  "Business / Program Operations",
  "Fintech / Product Operations",
  "AI Finance / AI Product Testing",
  "AML / KYC / Client Onboarding",
];

const experience = [
  {
    company: "Crédito Agrícola",
    role: "Banking Assistant – Banca de Retalho, Crédito & Produtos Financeiros",
    period: "2025 – Presente",
    description:
      "Experiência transversal em banca de retalho orientada para cliente, cobrindo operações diárias de balcão, pedidos de clientes, operações de caixa, tarefas relacionadas com ATM, procedimentos de cofre e tesouraria, cartões de crédito, crédito ao consumo, crédito habitação e processos de crédito hipotecário e não hipotecário, seguros, produtos de poupança e investimento, revisão documental, validação de dados de cliente e workflows bancários regulados.",
    highlights: [
      "Apoio a uma ampla variedade de operações de banca de retalho e balcão, incluindo pedidos de clientes, operações de caixa, tarefas relacionadas com ATM, procedimentos de cofre e workflows de tesouraria.",
      "Trabalho com cartões de crédito, crédito ao consumo, crédito habitação, processos de crédito hipotecário e não hipotecário, seguros, produtos de poupança e produtos financeiros relacionados com investimento.",
      "Revisão de documentação de clientes, informação de conta e requisitos operacionais com atenção a AML/KYC, rigor nos processos de crédito e qualidade dos dados de cliente.",
      "Desenvolvimento de exposição prática a workflows end-to-end de banca de retalho, serviço ao cliente, operações de produtos financeiros, processos de crédito e controlos bancários regulados.",
    ],
  },
  {
    company: "Banco BiG",
    role: "Personal Wealth Management",
    period: "2023 – 2025",
    description:
      "Experiência em wealth management, apoio a investment advisory, produtos financeiros, contexto MiFID II, comunicação com stakeholders e workflows bancários orientados para cliente.",
    highlights: [
      "Trabalho num ambiente bancário orientado para wealth management e investimento.",
      "Exposição a produtos financeiros, carteiras de clientes e processos regulados de aconselhamento.",
      "Reforço de conhecimento em MiFID II, AML/KYC e processos de documentação de cliente.",
      "Desenvolvimento de competências de comunicação com clientes, equipas internas e stakeholders financeiros.",

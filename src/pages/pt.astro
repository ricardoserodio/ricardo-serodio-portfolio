    stack: ["Python", "Streamlit", "pandas", "Plotly", "Validação de dados"],
    links: [
      {
        label: "App",
        href: "https://pt-deposit-comparator.streamlit.app",
      },
      {
        label: "GitHub",
        href: "https://github.com/ricardoserodio/portugal-term-deposit-comparator",
      },
    ],
  },
  {

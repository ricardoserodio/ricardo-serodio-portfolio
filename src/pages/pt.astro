      "Streamlit",
      "Produtos Financeiros",
      "Validação de Dados",
      "Source Mapping",
      "Banking Analytics",
    ],
    github: "https://github.com/ricardoserodio/portugal-term-deposit-comparator",
    live: "https://pt-deposit-comparator.streamlit.app",
  },
  {
    name: "Financial Modeling Case Study – Millennium bcp",
    status: "In Progress / Case Study",
    description:
      "Caso de estudo de banking analytics e financial modeling com dados públicos, combinando análise financeira, rácios bancários, pressupostos de forecast, análise de cenários e validação de qualidade dos dados financeiros.",
    skills: [
      "Financial Modeling",
      "Rácios Bancários",
      "Dados Públicos",
      "SQL",
      "Power BI",
      "Análise de Cenários",
    ],
    github: "",
    live: "",

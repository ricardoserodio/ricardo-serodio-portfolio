const experience = [
  {
    company: "Crédito Agrícola",
    role: "Banking Assistant – Retail Banking Operations",
    period: "Maio 2025 – Presente",
    location: "Tavira, Faro, Portugal",
    description:
      "Experiência em operações bancárias de retalho num grupo bancário cooperativo português, com apoio ao atendimento, processos de crédito, revisão documental e workflows bancários regulados.",
    bullets: [
      "Gestão de operações bancárias diárias de elevado volume, incluindo atendimento, operações de caixa, tesouraria, tarefas relacionadas com ATM e procedimentos de segurança.",
      "Apoio a processos de crédito ao consumo e crédito hipotecário, incluindo revisão documental, análise financeira, avaliação de esforço e análise do perfil de risco do cliente.",
      "Execução de procedimentos KYC e Customer Due Diligence, apoiando o cumprimento de requisitos AML/CFT, políticas internas e onboarding regulado.",
      "Revisão de documentação de clientes, dados de onboarding e requisitos de abertura de conta, contribuindo para a qualidade operacional e validação de informação.",
    ],
  },
  {
    company: "Banco BiG",
    role: "Client Manager – Personal Wealth Management",
    period: "Maio 2023 – Maio 2025",
    location: "Loulé, Faro, Portugal",
    description:
      "Experiência em personal wealth management e apoio à consultoria para investimento num banco de investimento português, com foco em estruturação de carteiras, relacionamento com clientes e processos regulados de investimento.",
    bullets: [
      "Apoio à consultoria para investimento no enquadramento MiFID II, ajudando clientes a alinhar carteiras com perfis de risco, objectivos de investimento e necessidades financeiras.",
      "Gestão e desenvolvimento de relações com clientes numa carteira dedicada de personal wealth management, entregando soluções ajustadas e apoiando a retenção de clientes.",
      "Contribuição para estruturação de carteiras e asset allocation em acções, instrumentos de rendimento fixo e produtos de investimento.",
      "Monitorização de mercados financeiros, produtos de investimento e carteiras de clientes, identificando oportunidades de rebalanceamento e apoiando a tomada de decisão.",
